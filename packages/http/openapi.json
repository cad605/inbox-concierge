          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "allOf": [
                      {
                        "pattern": "^\\S[\\s\\S]*\\S$|^\\S$|^$"
                      },
                      {
                        "minLength": 1
                      }
                    ]
                  },
                  "prompt": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "examples": {
                    "anyOf": [
                      {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "allOf": [
                            {
                              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000)$",
                              "format": "uuid"
                            }
                          ]
                        },
                        "allOf": [
                          {
                            "maxItems": 5
                          }
                        ]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": ["name"],
                "additionalProperties": false
              }
            }
          },
          "required": true
        }
      }
    },
