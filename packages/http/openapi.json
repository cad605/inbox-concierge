  "components": {
    "schemas": {
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000)$",
                "format": "uuid"
              }
            ]
          },
          "email": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^\\S[\\s\\S]*\\S$|^\\S$|^$"
              },
              {
                "pattern": "^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$"
              }
            ]
          },
          "displayName": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^\\S[\\s\\S]*\\S$|^\\S$|^$"
              },
              {
                "minLength": 1
              }
            ]
          },
          "role": {
            "type": "string",
            "enum": ["admin", "user"]
          },
          "primaryProvider": {
            "anyOf": [
              {
                "type": "string",
                "enum": ["google"]
              }
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "displayName",
          "role",
          "primaryProvider",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      },
      "UnauthorizedError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["UnauthorizedError"]
          }
        },
        "required": ["_tag"],
        "additionalProperties": false
      },
      "AuthPersistenceError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["AuthPersistenceError"]
          },
          "message": {
            "type": "string",
            "enum": ["A database error occurred while processing authentication data."]
          }
        },
        "required": ["_tag", "message"],
        "additionalProperties": false
      },
      "SessionNotFoundError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["SessionNotFoundError"]
          }
        },
        "required": ["_tag"],
        "additionalProperties": false
      },
      "PendingPersistedJobCounts": {
        "type": "object",
        "properties": {
          "userInboxSyncCount": {
            "type": "integer"
          },
          "messageAutoLabelCount": {
            "type": "integer"
          }
        },
        "required": ["userInboxSyncCount", "messageAutoLabelCount"],
        "additionalProperties": false
      },
      "DatabaseUnavailableError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["DatabaseUnavailableError"]
          },
          "message": {
            "type": "string",
            "enum": ["Service temporarily unavailable."]
          }
        },
        "required": ["_tag", "message"],
        "additionalProperties": false
      },
      "PermissionDeniedError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["PermissionDeniedError"]
          }
        },
        "required": ["_tag"],
        "additionalProperties": false
      },
      "Label": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000)$",
                "format": "uuid"
              }
            ]
          },
          "userId": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000)$",
                "format": "uuid"
              }
            ]
          },
          "name": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^\\S[\\s\\S]*\\S$|^\\S$|^$"
              },
              {
                "minLength": 1
              }
            ]
          },
          "prompt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": {
            "type": "string",
            "enum": ["system", "custom"]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "name",
          "prompt",
          "type",
          "isActive",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      },
      "LabelPersistenceError": {
        "type": "object",
        "properties": {
          "_tag": {
            "type": "string",
            "enum": ["LabelPersistenceError"]
          },
          "message": {
            "type": "string",
            "enum": ["A database error occurred while processing labels."]
          }
        },
        "required": ["_tag", "message"],
        "additionalProperties": false
      },
