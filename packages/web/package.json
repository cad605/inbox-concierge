{
  "name": "@workspace/web",
  "private": true,
  "type": "module",
  "main": "index.js",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "component:add": "bunx @chakra-ui/cli snippet add --outdir ./src/ui/components --tsx --",
    "dev": "vite dev --port 3001",
    "chakra:types": "bunx @chakra-ui/cli typegen ./src/theme.ts --tsconfig ./tsconfig.json",
    "postinstall": "bun run chakra:types",
    "serve": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "3.34.0",
    "@emotion/react": "11.14.0",
    "@inlang/paraglide-js": "2.15.1",
    "@tanstack/db": "0.6.2",
    "@tanstack/query-core": "5.96.2",
    "@tanstack/query-db-collection": "1.0.33",
    "@tanstack/react-db": "0.1.80",
    "@tanstack/react-form": "1.28.4",
    "@tanstack/react-query": "5.96.2",
    "@tanstack/react-query-devtools": "5.96.2",
    "@tanstack/react-router": "1.166.2",
    "@tanstack/react-router-devtools": "1.166.2",
    "@tanstack/react-virtual": "3.13.19",
    "@tanstack/router-plugin": "1.166.2",
    "@workspace/backend": "workspace:*",
    "@workspace/http": "workspace:*",
    "effect": "catalog:",
    "envalid": "8.1.1",
    "next-themes": "0.4.6",
    "openapi-fetch": "0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0"
  },
  "devDependencies": {
    "@chakra-ui/cli": "3.34.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@workspace/tsconfig": "catalog:",
    "typescript": "catalog:",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1"
  }
}
