# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/inbox-concierge
PG_SSL=false

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
# Must match the callback URL registered in Google Cloud (this API route, not the SPA)
AUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Browser redirect after OAuth (SPA origin; differs from AUTH_GOOGLE_REDIRECT_URI)
WEB_APP_URL=http://localhost:3001

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Model id (https://openrouter.ai/models); default: openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# Server
PORT=3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:*
